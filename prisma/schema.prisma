// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SubscriptionPlan {
  FREE_TIER
  PRO
  BUSINESS
}

enum UserRole {
  DEFAULT
  ADMIN
}

enum EmbeddingKind {
  NORMALIZED_PROMPT
  FINAL_PROMPT
  VISUAL_TAG
  FEEDBACK
}

enum GenerationStatus {
  PENDING
  COMPLETED
  FAILED
}

model Plan {
  id           SubscriptionPlan @id
  name         String
  description  String?
  stylizeLimit Int?
  benefits     String[]         @default([])
  hasImageStorage Boolean       @default(true)
  stripePriceId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users User[]
}

model User {
  id                       String   @id @default(uuid())
  name                     String
  email                    String   @unique
  pendingEmail             String?  @unique
  avatarUrl                String?
  password                 String
  role                     UserRole @default(DEFAULT)
  subscriptionPlan         SubscriptionPlan @default(FREE_TIER)
  plan                     Plan     @relation(fields: [subscriptionPlan], references: [id])
  stylizeUsageCount        Int      @default(0)
  stylizeUsagePeriod       String   @default("1970-01")
  verifiedAt               DateTime?
  verificationToken        String?
  verificationTokenExpires DateTime?
  emailChangeToken         String?
  emailChangeTokenExpires  DateTime?
  passwordResetToken       String?
  passwordResetTokenExpires DateTime?
  lastEmailChangeSentAt    DateTime?
  lastPasswordResetSentAt  DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  uploads UserUpload[]
  generations ImageGeneration[]
  feedbacks ImageFeedback[]
  ragEmbeddings RagEmbedding[]
  presets Preset[]
  derivatives ImageDerivative[]
  collections Collection[]
  pushSubscriptions PushSubscription[]
  notificationReads NotificationRead[]
}

model UserUpload {
  id             String   @id @default(uuid())
  userId         String
  url            String   @unique
  style          String?
  prompt         String?  @db.Text
  tags           String[] @default([])
  favorite       Boolean  @default(false)
  collectionId   String?
  lastAccessedAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  generation ImageGeneration?
}

model ImageGeneration {
  id                 String          @id @default(uuid())
  userId             String
  userUploadId       String?         @unique
  parentGenerationId String?
  status             GenerationStatus @default(PENDING)
  inputImageType     String?
  inputImageSize     Int?
  rawPrompt          String          @db.Text
  stylePrompt        String?
  finalPrompt        String?         @db.Text
  modelUsed          String?
  ragContext         Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  upload      UserUpload?        @relation(fields: [userUploadId], references: [id], onDelete: SetNull)
  parent      ImageGeneration?   @relation("GenerationVariants", fields: [parentGenerationId], references: [id], onDelete: Cascade)
  variants    ImageGeneration[]  @relation("GenerationVariants")
  normalization PromptNormalization?
  embeddings  RagEmbedding[]
  feedbacks   ImageFeedback[]
  derivatives ImageDerivative[]
}

model Collection {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploads UserUpload[]

  @@index([userId])
}

model PromptNormalization {
  id            String   @id @default(uuid())
  generationId  String   @unique
  intent        String?
  emotion       String?
  style         String?
  visualTags    String[] @default([])
  parameters    Json?
  normalizedText String  @db.Text
  createdAt     DateTime @default(now())

  generation ImageGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)
}

model RagEmbedding {
  id           String        @id @default(uuid())
  userId       String?
  generationId String?
  feedbackId   String?
  kind         EmbeddingKind
  content      String        @db.Text
  embedding    Unsupported("vector")
  createdAt    DateTime      @default(now())

  user       User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  generation ImageGeneration? @relation(fields: [generationId], references: [id], onDelete: Cascade)
  feedback   ImageFeedback?   @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
}

model ImageFeedback {
  id           String   @id @default(uuid())
  userId       String
  generationId String
  rating       Int?
  comment      String? @db.Text
  tags         String[] @default([])
  createdAt    DateTime @default(now())

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  generation ImageGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)
  embeddings RagEmbedding[]
}

model Preset {
  id        String   @id @default(uuid())
  userId    String
  name      String
  style     String?
  prompt    String?  @db.Text
  intent    String?
  emotion   String?
  lighting  String?
  palette   String?
  framing   String?
  details   String?
  tags      String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum DerivativeKind {
  CROP
}

model ImageDerivative {
  id           String         @id @default(uuid())
  userId       String
  generationId String
  kind         DerivativeKind
  aspectRatio  String
  width        Int
  height       Int
  url          String
  createdAt    DateTime       @default(now())

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  generation ImageGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)
}

model AdminNotification {
  id        String   @id @default(uuid())
  title     String
  body      String   @db.Text
  audience  String
  createdAt DateTime @default(now())

  reads NotificationRead[]
}

model NotificationRead {
  id             String   @id @default(uuid())
  userId         String
  notificationId String
  readAt         DateTime @default(now())

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  notification AdminNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Promotion {
  id                    String   @id @default(uuid())
  code                  String   @unique
  discountPercent       Int
  maxRedemptions        Int?
  expiresAt             DateTime?
  stripeCouponId        String?
  stripePromotionCodeId String?
  createdAt             DateTime @default(now())
}
