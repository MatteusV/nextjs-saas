generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SubscriptionPlan {
  FREE_TIER
  PRO
  BUSINESS
}

model Plan {
  id           SubscriptionPlan @id
  name         String
  description  String?
  stylizeLimit Int?
  stripePriceId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users User[]
}

model User {
  id                       String   @id @default(uuid())
  name                     String
  email                    String   @unique
  password                 String
  subscriptionPlan         SubscriptionPlan @default(FREE_TIER)
  plan                     Plan     @relation(fields: [subscriptionPlan], references: [id])
  stylizeUsageCount        Int      @default(0)
  stylizeUsagePeriod       String   @default("1970-01")
  verifiedAt               DateTime?
  verificationToken        String?
  verificationTokenExpires DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  uploads UserUpload[]
}

model UserUpload {
  id             String   @id @default(uuid())
  userId         String
  url            String   @unique
  prompt         String?  @db.Text
  lastAccessedAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
